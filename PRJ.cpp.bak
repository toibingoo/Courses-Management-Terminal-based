// ============================================================
//  ANSI COLOR CODES
// ============================================================
namespace C {
    const string R  = "\033[0m";       // Reset
    const string B  = "\033[1m";       // Bold
    const string RD = "\033[91m";      // Red
    const string GR = "\033[92m";      // Green
    const string YL = "\033[93m";      // Yellow
    const string BL = "\033[94m";      // Blue
    const string MG = "\033[95m";      // Magenta
    const string CY = "\033[96m";      // Cyan
    const string WH = "\033[97m";      // White
}

// ============================================================
//  DATA STRUCTURES
// ============================================================
struct Schedule {
    int    dayOfWeek;   // 2=T2, 3=T3, 4=T4, 5=T5, 6=T6, 7=T7, 8=CN
    string timeSlot;    // e.g. "07:00-09:30"
    string room;        // e.g. "D3-209"
};

struct Student {
    string name;
    string studentId;
};

struct Lecturer {
    string name;
    string staffId;
    string status;
};

struct Class {
    string         className;
    int            classCode;       // unique 1000-9999
    string         semester;
    int            lecturerIndex;   // index into lecturers[]
    vector<Schedule> schedules;
    vector<int>    studentIndices;  // indices into students[]
};

// ============================================================
//  GLOBAL DATA
// ============================================================
vector<Student>  students;
vector<Lecturer> lecturers;
vector<Class>    classes;
set<int>         usedCodes;

// ============================================================
//  APP STATE  (navigation state machine)
// ============================================================
enum class Screen {
    MENU, TIMETABLE,
    CLASS_LIST, CLASS_DETAIL,
    LECTURER_DETAIL, LECTURER_COURSES,
    STUDENT_LIST
};

struct AppState {
    Screen screen            = Screen::MENU;
    int    weekOffset        = 0;   // 0=this week
    int    classPage         = 0;
    int    classIdx          = -1;
    int    lecturerIdx       = -1;
    int    lecturerCoursePage = 0;
    int    studentPage       = 0;
} S;

// ============================================================
//  UTILITY FUNCTIONS
// ============================================================
void enableAnsi() {
#ifdef _WIN32
    HANDLE h = GetStdHandle(STD_OUTPUT_HANDLE);
    DWORD  m = 0;
    GetConsoleMode(h, &m);
    SetConsoleMode(h, m | ENABLE_VIRTUAL_TERMINAL_PROCESSING);
    SetConsoleOutputCP(65001);
#endif
}

void cls() {
#ifdef _WIN32
    system("cls");
#else
    system("clear");
#endif
}

// Center a string within a fixed width
string centerStr(const string& s, int w) {
    int len = (int)s.size();
    if (len >= w) return s.substr(0, w);
    int l = (w - len) / 2;
    return string(l, ' ') + s + string(w - len - l, ' ');
}

// Truncate string if too long
string trunc(const string& s, int maxLen) {
    if ((int)s.size() <= maxLen) return s;
    return s.substr(0, maxLen - 3) + "...";
}

// Vietnamese day names (2-8)
string dayName(int d) {
    switch (d) {
        case 2: return "Thu Hai";   case 3: return "Thu Ba";
        case 4: return "Thu Tu";    case 5: return "Thu Nam";
        case 6: return "Thu Sau";   case 7: return "Thu Bay";
        case 8: return "Chu Nhat";  default: return "???";
    }
}
string dayShort(int d) {
    switch (d) {
        case 2: return "T2"; case 3: return "T3"; case 4: return "T4";
        case 5: return "T5"; case 6: return "T6"; case 7: return "T7";
        case 8: return "CN"; default: return "??";
    }
}

// Get today's day code (2=T2 ... 8=CN)
int todayCode() {
    time_t  now = time(nullptr);
    struct tm* t = localtime(&now);
    int wday = t->tm_wday;          // 0=Sun
    return (wday == 0) ? 8 : wday + 1;
}

// Current semester string e.g. "20252"
string currentSemester() {
    time_t  now = time(nullptr);
    struct tm* t = localtime(&now);
    int m = t->tm_mon + 1;
    int y = t->tm_year + 1900;
    if (m >= 9)              return to_string(y)   + "1";
    if (m == 1)              return to_string(y-1) + "1";
    if (m >= 2 && m <= 6)   return to_string(y)   + "2";
    return to_string(y) + "3";  // July-August
}

// Format time_t as "dd/mm"
string fmtDate(time_t t) {
    struct tm* tm = localtime(&t);
    char buf[10];
    sprintf(buf, "%02d/%02d", tm->tm_mday, tm->tm_mon + 1);
    return buf;
}

// Format time_t as "dd/mm/yyyy"
string fmtDateFull(time_t t) {
    struct tm* tm = localtime(&t);
    char buf[12];
    sprintf(buf, "%02d/%02d/%04d", tm->tm_mday, tm->tm_mon+1, tm->tm_year+1900);
    return buf;
}

// Monday time_t for (current week + weekOffset)
time_t weekMonday(int offset) {
    time_t now = time(nullptr);
    struct tm* t = localtime(&now);
    t->tm_hour = 12; t->tm_min = 0; t->tm_sec = 0;
    now = mktime(t);
    int dow = t->tm_wday;
    if (dow == 0) dow = 7;
    now -= (time_t)(dow - 1) * 86400;
    now += (time_t)offset * 7 * 86400;
    return now;
}

// ISO week number
int weekNumber(time_t t) {
    struct tm* tm = localtime(&t);
    char buf[5];
    strftime(buf, sizeof(buf), "%V", tm);
    return atoi(buf);
}

// Indices of classes that have a session on dayCode
vector<int> classesOnDay(int dayCode) {
    vector<int> res;
    for (int i = 0; i < (int)classes.size(); i++)
        for (auto& sc : classes[i].schedules)
            if (sc.dayOfWeek == dayCode) { res.push_back(i); break; }
    return res;
}

// Generate a unique class code 1000-9999
int genCode() {
    static mt19937 rng((unsigned)time(nullptr));
    uniform_int_distribution<int> dist(1000, 9999);
    int code;
    do { code = dist(rng); } while (usedCodes.count(code));
    usedCodes.insert(code);
    return code;
}

// ============================================================
//  PRINT HELPERS
// ============================================================
void printHeader(const string& title, int w = 66) {
    string line(w, '=');
    cout << C::CY << line << C::R << "\n";
    cout << C::CY << "  " << C::B << C::WH << centerStr(title, w-4) << C::R << "\n";
    cout << C::CY << line << C::R << "\n";
}

void printSep(int w = 66, char ch = '-') {
    cout << C::CY << "  " << string(w - 2, ch) << C::R << "\n";
}

// ============================================================
//  FILE I/O  (data.txt)
// ============================================================
const string DATA_FILE = "data.txt";

// Schedule encoded as "day~timeSlot~room" with ';' between sessions
string encodeSchedules(const vector<Schedule>& v) {
    string r;
    for (int i = 0; i < (int)v.size(); i++) {
        if (i) r += ";";
        r += to_string(v[i].dayOfWeek) + "~" + v[i].timeSlot + "~" + v[i].room;
    }
    return r;
}
vector<Schedule> decodeSchedules(const string& s) {
    vector<Schedule> v;
    istringstream ss(s);
    string tok;
    while (getline(ss, tok, ';')) {
        if (tok.empty()) continue;
        istringstream ts(tok);
        string d, t, r;
        getline(ts, d, '~'); getline(ts, t, '~'); getline(ts, r, '~');
        try { v.push_back({stoi(d), t, r}); } catch (...) {}
    }
    return v;
}

string encodeInts(const vector<int>& v) {
    string r;
    for (int i = 0; i < (int)v.size(); i++) {
        if (i) r += ";";
        r += to_string(v[i]);
    }
    return r;
}
vector<int> decodeInts(const string& s) {
    vector<int> v;
    istringstream ss(s);
    string tok;
    while (getline(ss, tok, ';')) {
        if (!tok.empty()) try { v.push_back(stoi(tok)); } catch (...) {}
    }
    return v;
}

void saveData() {
    ofstream f(DATA_FILE);
    if (!f) return;
    f << "STUDENTS\n";
    for (auto& s : students)
        f << s.name << "|" << s.studentId << "\n";
    f << "LECTURERS\n";
    for (auto& l : lecturers)
        f << l.name << "|" << l.staffId << "|" << l.status << "\n";
    f << "CLASSES\n";
    for (auto& c : classes)
        f << c.className << "|" << c.classCode << "|" << c.semester << "|"
          << c.lecturerIndex << "|" << encodeSchedules(c.schedules) << "|"
          << encodeInts(c.studentIndices) << "\n";
}

void loadData() {
    ifstream f(DATA_FILE);
    if (!f) return;
    students.clear(); lecturers.clear(); classes.clear(); usedCodes.clear();
    string line, sec;
    while (getline(f, line)) {
        if (line == "STUDENTS")  { sec = "S"; continue; }
        if (line == "LECTURERS") { sec = "L"; continue; }
        if (line == "CLASSES")   { sec = "C"; continue; }
        if (line.empty()) continue;
        istringstream ss(line);
        string t;
        if (sec == "S") {
            Student st;
            getline(ss, st.name, '|'); getline(ss, st.studentId, '|');
            students.push_back(st);
        } else if (sec == "L") {
            Lecturer lc;
            getline(ss, lc.name, '|'); getline(ss, lc.staffId, '|'); getline(ss, lc.status, '|');
            lecturers.push_back(lc);
        } else if (sec == "C") {
            Class cl;
            string code, lIdx, scheds, studs;
            getline(ss, cl.className, '|');
            getline(ss, code, '|');
            getline(ss, cl.semester, '|');
            getline(ss, lIdx, '|');
            getline(ss, scheds, '|');
            getline(ss, studs);
            try { cl.classCode = stoi(code); } catch (...) { cl.classCode = genCode(); }
            try { cl.lecturerIndex = stoi(lIdx); } catch (...) { cl.lecturerIndex = 0; }
            cl.schedules      = decodeSchedules(scheds);
            cl.studentIndices = decodeInts(studs);
            usedCodes.insert(cl.classCode);
            classes.push_back(cl);
        }
    }
}

